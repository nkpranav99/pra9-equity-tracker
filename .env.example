# ============================================================
# Indian Equity Trading Bot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# --- Telegram Bot ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Your Telegram user ID (only this user can interact with the bot)
# Send /start to @userinfobot on Telegram to get your ID
TELEGRAM_OWNER_ID=your_telegram_user_id

# --- Zerodha Kite Connect ---
# Register at https://developers.kite.trade/
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
# --- Chartink ---
# Comma-separated list of Chartink screener slugs (the URL path after /screener/)
# Example: "my-breakout-scanner,volume-spike-scanner"
CHARTINK_SCREENER_SLUGS=your_screener_slug_1,your_screener_slug_2

# --- Scan Settings ---
# How often to scan screeners during market hours (in minutes)
SCAN_INTERVAL_MINUTES=15
# Market hours (IST, 24h format)
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=15
MARKET_CLOSE_HOUR=15
MARKET_CLOSE_MINUTE=30

# --- Database ---
DB_PATH=./data/equity-bot.db

# --- Logging ---
LOG_LEVEL=info
